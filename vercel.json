{
  "version": 2,
  "functions": {
    "api/doubao.js": {
      "maxDuration": 300
    },
    "api/bailian.js": {
      "maxDuration": 300
    },
    "api/fangzhou.js": {
      "maxDuration": 300
    },
    "api/proxy-url.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
